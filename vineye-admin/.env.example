DATABASE_URL="postgresql://user:password@localhost:5432/vineye_admin"
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Rate limiting de /api/mobile/predict (Upstash Redis — https://upstash.com)
# À configurer dans Vercel Settings > Environment Variables pour la prod.
# Sans ces variables, le rate limit est désactivé (no-op).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
